.com-optimize.gif) !important}.gif-hover-denuncias{background-image:url() !important}li.et_pb_menu_page_id-home:hover .gif-hover-inicio,li.et_pb_menu_page_id-83759:hover .gif-hover-tramites,li.et_pb_menu_page_id-228:hover .gif-hover-noticias,li.et_pb_menu_page_id-2026:hover .gif-hover-transparencia,li.et_pb_menu_page_id-230:hover .gif-hover-atencion,li.et_pb_menu_page_id-231:hover .gif-hover-participa,li.et_pb_menu_page_id-215202:hover .gif-hover-denuncias{opacity:1 !important;visibility:visible !important;transform:translateY(0) !important}@media (max-width:980px){.gif-hover-inicio,.gif-hover-tramites,.gif-hover-noticias,.gif-hover-transparencia,.gif-hover-atencion,.gif-hover-participa,.gif-hover-denuncias{display:none !important}}</style> <script>jQuery(document).ready(function($) {
    setTimeout(function() {
        // Array con la configuración de cada botón
        var menuItems = [
            { class: '.et_pb_menu_page_id-home', gifClass: 'gif-hover-inicio', name: 'Inicio' },
            { class: '.et_pb_menu_page_id-83759', gifClass: 'gif-hover-tramites', name: 'Paga tus impuestos' },
            { class: '.et_pb_menu_page_id-228', gifClass: 'gif-hover-noticias', name: 'Noticias' },
            { class: '.et_pb_menu_page_id-2026', gifClass: 'gif-hover-transparencia', name: 'Transparencia' },
            { class: '.et_pb_menu_page_id-230', gifClass: 'gif-hover-atencion', name: 'Atención y servicios' },
            { class: '.et_pb_menu_page_id-231', gifClass: 'gif-hover-participa', name: 'Participa' },
            { class: '.et_pb_menu_page_id-215202', gifClass: 'gif-hover-denuncias', name: 'Canal Denuncias Corrupción' }
        ];
        
        // Agregar cada GIF
        menuItems.forEach(function(item) {
            var menuElement = $(item.class);
            if (menuElement.length > 0) {
                var gifDiv = $('<div class="' + item.gifClass + '"></div>');
                menuElement.append(gifDiv);
                console.log('✓ GIF ' + item.name + ' agregado correctamente');
            } else {
                console.log('✗ No se encontró el menú ' + item.name);
            }
        });
        
        // Forzar overflow visible
        $('.pa-menu-without-logo .et_pb_menu__wrap, .pa-menu-without-logo .et_pb_menu__menu, .pa-menu-without-logo .et_pb_menu__menu > nav, .pa-menu-without-logo .et_pb_menu__menu > nav > ul')
            .css('overflow', 'visible');
        
        console.log('==================');
        console.log('✓ Todos los GIFs del menú han sido configurados');
        console.log('==================');
        
    }, 1000);
});</script> <link rel="icon" href="https://sp-ao.shortpixel.ai/client/to_webp,q_glossy,ret_img,w_32,h_32/https://www.bucaramanga.gov.co/wp-content/uploads/2021/03/cropped-Logo-alcaldia-32x32.png" sizes="32x32" /><link rel="icon" href="https://sp-ao.shortpixel.ai/client/to_webp,q_glossy,ret_img,w_192,h_192/https://www.bucaramanga.gov.co/wp-content/uploads/2021/03/cropped-Logo-alcaldia-192x192.png" sizes="192x192" /><link rel="apple-touch-icon" href="https://sp-ao.shortpixel.ai/client/to_webp,q_glossy,ret_img,w_180,h_180/https://www.bucaramanga.gov.co/wp-content/uploads/2021/03/cropped-Logo-alcaldia-180x180.png" /><meta name="msapplication-TileImage" content="https://www.bucaramanga.gov.co/wp-content/uploads/2021/03/cropped-Logo-alcaldia-270x270.png" /></head><body class="post-template-default single single-post postid-94884 single-format-standard et-tb-has-template et-tb-has-header et-tb-has-footer dbdb_divi_2_4_up desktop non-logged-in et_pb_button_helper_class et_cover_background et_pb_gutter windows et_pb_gutters3 et_pb_pagebuilder_layout et_right_sidebar et_divi_theme et-db el-divi-blog-extras-archive-template">
