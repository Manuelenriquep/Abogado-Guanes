    <script>
        // ==========================================
        // MAPA WOMPI: link Ãºnico para todos los documentos de $19.900
        // ==========================================
        const WOMPI_URL = 'https://checkout.wompi.co/l/y0fJnm';

        const WOMPI_LINKS = {
            'arrendamiento': { link: WOMPI_URL, label: 'Contrato de Arrendamiento' },
            'tutela': { link: WOMPI_URL, label: 'AcciÃ³n de Tutela' },
            'peticion': { link: WOMPI_URL, label: 'Derecho de PeticiÃ³n' },
            'promesa': { link: WOMPI_URL, label: 'Promesa de Compraventa' },
            'alimentos': { link: WOMPI_URL, label: 'Demanda de Alimentos' },
            'liquidacion': { link: WOMPI_URL, label: 'Reclamo de LiquidaciÃ³n Laboral' },
        };

        // Detecta si la respuesta menciona un documento y retorna el botÃ³n HTML de Wompi
        function detectarBotonPago(texto) {
            const lower = texto.toLowerCase();
            for (const [key, doc] of Object.entries(WOMPI_LINKS)) {
                if (lower.includes(key) && lower.includes('19.900')) {
                    // AÃ±adimos el tipo de documento como referencia para que N8N
                    // sepa quÃ© PDF entregar automÃ¡ticamente despuÃ©s del pago
                    const linkConRef = `${doc.link}?reference=${key}`;
                    return `
                    <div class="mt-4 pt-3 border-t border-white/10">
                        <a href="${linkConRef}" target="_blank" rel="noopener noreferrer"
                            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-green-600 to-emerald-500 hover:from-green-500 hover:to-emerald-400 text-white text-sm font-bold transition-all shadow-lg shadow-green-500/20 border border-green-400/30">
                            ðŸ’³ Obtener: ${doc.label} â€” $19.900 COP
                        </a>
                    </div>`;
                }
            }
            return '';
        }

        // FunciÃ³n para usar chips: llena el input y envÃ­a automÃ¡ticamente
        function usarChip(btn) {
            const msg = btn.getAttribute('data-msg');
            document.getElementById('chat-input-n8n').value = msg;
            // Ocultar chips despuÃ©s del primer uso para dar espacio al chat
            document.getElementById('chips-container')?.remove();
            enviarMensajeN8N();
        }

        // ==========================================
        // MOTOR DE CHAT LLM (CONEXIÃ“N N8N)
        // ==========================================
        async function enviarMensajeN8N() {
            const inputField = document.getElementById('chat-input-n8n');
            const mensaje = inputField.value.trim();
            if (!mensaje) return;

            const chatMessages = document.getElementById('chat-messages');

            // 1. Mostrar mensaje del usuario
            const userHtml = `
                <div class="flex items-start gap-4 flex-row-reverse self-end max-w-[85%] animate-fade-in mt-4">
                    <div class="w-10 h-10 rounded-lg bg-blue-900 border border-blue-500/40 flex items-center justify-center shrink-0 text-white shadow-[0_0_15px_rgba(37,99,235,0.15)]">
                        ðŸ‘¤
                    </div>
                    <div class="bg-blue-600/20 p-4 md:p-5 rounded-2xl rounded-tr-none border border-blue-500/30 text-sm md:text-base text-white shadow-lg leading-relaxed">
                        ${mensaje}
                    </div>
                </div>
            `;
            chatMessages.insertAdjacentHTML('beforeend', userHtml);
            inputField.value = '';
            chatMessages.scrollTop = chatMessages.scrollHeight;

            // 2. Mostrar "Escribiendo..."
            const typingId = 'typing-' + Date.now();
            const typingHtml = `
                <div id="${typingId}" class="flex items-start gap-4 max-w-[85%] mt-4 animate-fade-in">
                    <div class="w-10 h-10 rounded-lg bg-cyan-950 border border-cyan-500/40 flex items-center justify-center shrink-0 text-cyan-400">
                        âš–ï¸
                    </div>
                    <div class="bg-slate-800/80 p-4 rounded-2xl rounded-tl-none border border-white/5 flex items-center gap-2">
                        <div class="w-2 h-2 bg-cyan-400 rounded-full animate-bounce"></div>
                        <div class="w-2 h-2 bg-cyan-400 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                        <div class="w-2 h-2 bg-cyan-400 rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
                    </div>
                </div>
            `;
            chatMessages.insertAdjacentHTML('beforeend', typingHtml);
            chatMessages.scrollTop = chatMessages.scrollHeight;

            try {
                // Notar que este es el N8N de produccion.
                const apiUrl = 'https://n8n-production-612f.up.railway.app/webhook/cb4edfe2-eaea-47dd-8f97-22afccd72810';
                const response = await fetch(apiUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mensaje: mensaje, session_id: "web-client" })
                });

                document.getElementById(typingId).remove();

                if (!response.ok) throw new Error("Error en la respuesta del webhook N8N");

                const rawText = await response.text();
                let respuestaIA = "OcurriÃ³ un error procesando la respuesta.";

                try {
                    const data = JSON.parse(rawText);
                    // N8N puede devolver un array o un objeto directamente
                    const finalData = Array.isArray(data) ? data[0] : data;
                    respuestaIA = finalData.output || finalData.respuesta || finalData.text || rawText;
                } catch (e) {
                    respuestaIA = rawText;
                }

                // 3. Mostrar respuesta IA + detectar si es para comprar
                const botHtml = `
                    <div class="flex items-start gap-4 max-w-[90%] mt-4 animate-fade-in">
                        <div class="w-10 h-10 rounded-lg bg-cyan-950 border border-cyan-500/40 flex items-center justify-center shrink-0 text-cyan-400 shadow-[0_0_15px_rgba(0,255,255,0.15)]">
                            âš–ï¸
                        </div>
                        <div class="bg-slate-800/80 p-4 md:p-5 rounded-2xl rounded-tl-none border border-white/5 text-sm md:text-base text-slate-200 shadow-lg leading-relaxed whitespace-pre-wrap">
                            ${respuestaIA}
                            ${detectarBotonPago(respuestaIA)}
                        </div>
                    </div>
                `;
                chatMessages.insertAdjacentHTML('beforeend', botHtml);

            } catch (error) {
                console.error(error);
                document.getElementById(typingId)?.remove();
                const errorHtml = `
                    <div class="flex items-start gap-4 max-w-[85%] mt-4 animate-fade-in">
                        <div class="w-10 h-10 rounded-lg bg-red-950 border border-red-500/40 flex items-center justify-center shrink-0 text-red-400 font-bold">
                            âš ï¸
                        </div>
                        <div class="bg-red-900/20 p-4 rounded-2xl rounded-tl-none border border-red-500/30 text-sm text-red-200">
                            Error de conexiÃ³n con el nÃºcleo Guanes IA. Por favor, reintente.
                        </div>
                    </div>
                `;
                chatMessages.insertAdjacentHTML('beforeend', errorHtml);
            }
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        // ==========================================
        // SCROLL REVEAL ENGINE
        // ==========================================
        document.addEventListener('DOMContentLoaded', () => {
            const observerOptions = {
                threshold: 0.1
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
        });

        // ==========================================
        // SOLUCIONES GUANES (Noticiero Automatizado)
        // ==========================================
        async function cargarSolucionesGuanes() {
            const container = document.getElementById('soluciones-container');
            if (!container) return;

            try {
                // Forzamos evitar cachÃ© agregando un timestamp
                const res = await fetch(`js/noticias.json?t=${new Date().getTime()}`);
                if (!res.ok) throw new Error("No se pudo cargar el JSON del Radar.");
                const noticias = await res.json();

                container.innerHTML = ''; // Limpiar

                noticias.forEach(noticia => {
                    const htmlCard = `
            <div class="bg-slate-900/80 border border-slate-700 rounded-xl p-5 hover:border-cyan-500/50 transition-colors group">
                            <div class="flex justify-between items-start mb-3">
                                <h3 class="text-white font-bold text-sm md:text-base group-hover:text-cyan-400 transition-colors">${noticia.titulo}</h3>
                                <span class="text-xs text-slate-500 font-mono bg-slate-950 px-2 py-1 rounded">${noticia.fecha}</span>
                            </div>
                            <p class="text-slate-400 text-sm mb-4 leading-relaxed">${noticia.impacto}</p>
                            <div class="bg-cyan-950/30 border border-cyan-500/20 rounded p-3 mt-4 text-center">
                                <span class="text-xs text-cyan-400 font-bold uppercase tracking-wider block mb-2">Nuestra SoluciÃ³n</span>
                                <p class="text-slate-200 text-sm font-semibold">"${noticia.accion}"</p>
                            </div>
                        </div>
            `;
                    container.innerHTML += htmlCard;
                });

            } catch (error) {
                console.warn("âš ï¸ Soluciones Guanes: Usando datos de respaldo.", error);
                // Fallback de autoridad si falla la carga
                container.innerHTML = `
                    <div class="bg-slate-900/80 border border-slate-700 rounded-xl p-5">
                        <div class="flex justify-between items-start mb-3">
                            <h3 class="text-white font-bold text-sm md:text-base">AuditorÃ­a Inteligente: Ley 675 (2025)</h3>
                            <span class="text-xs text-slate-500 font-mono bg-slate-950 px-2 py-1 rounded">HOY</span>
                        </div>
                        <p class="text-slate-400 text-sm mb-4 leading-relaxed">El Decreto 768 de 2025 regula mascotas y Airbnb en copropiedades. Muchos reglamentos estÃ¡n desactualizados y son impugnables.</p>
                        <div class="bg-cyan-950/30 border border-cyan-500/20 rounded p-3 mt-4 text-center">
                            <span class="text-xs text-cyan-400 font-bold uppercase tracking-wider block mb-2">Nuestra SoluciÃ³n</span>
                            <p class="text-slate-200 text-sm font-semibold">Actualizamos manuales de convivencia y reglamentos bajo el nuevo Decreto 768 â€” Consulta Experta.</p>
                        </div>
                    </div>`;
            }
        }

        // ==========================================
        // CALCULADORA LABORAL (N8N)
        // ==========================================
        async function calcularLiquidacion() {
            const btn = document.getElementById('btn-calcular');
            const spinner = document.getElementById('calc-spinner');
            const emptyState = document.getElementById('calc-empty');
            const results = document.getElementById('calc-resultados');
            const ctaIndemnizacion = document.getElementById('cta-indemnizacion');

            const fechaInicio = document.getElementById('calc-inicio').value;
            const fechaFin = document.getElementById('calc-fin').value;
            const salario = document.getElementById('calc-salario').value;
            const motivo = document.getElementById('calc-motivo').value;

            // Simple validation
            if (!fechaInicio || !fechaFin || !salario || !motivo) {
                alert('âš ï¸ Guanes IA: Faltan parÃ¡metros para ejecutar el peritaje legal.');
                return;
            }

            // UI Feedback (Loading)
            btn.disabled = true;
            btn.classList.add('opacity-70');
            spinner.classList.remove('hidden');
            emptyState.classList.add('hidden');
            results.classList.add('hidden');
            ctaIndemnizacion.classList.add('hidden');

            try {
                // Fetch to Production N8N Webhook
                const response = await fetch('https://n8n-production-612f.up.railway.app/webhook/calculadora-laboral', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        fechaInicio,
                        fechaFin,
                        salario: Number(salario),
                        motivo
                    })
                });

                if (!response.ok) throw new Error('Error en el pipeline de N8N.');

                const data = await response.json();

                // Number formatting helper
                const formatCOP = (num) => {
                    const parsed = parseFloat(num);
                    if (isNaN(parsed)) return "$0";
                    return new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(parsed);
                };

                // Updating UI nodes
                document.getElementById('res-dias').innerText = data.diasLiquidados || data.dias_liquidados || "0";
                document.getElementById('res-cesantias').innerText = formatCOP(data.cesantias);
                document.getElementById('res-intereses').innerText = formatCOP(data.intereses || data.intereses_cesantias);
                document.getElementById('res-prima').innerText = formatCOP(data.prima || data.prima_servicios);
                document.getElementById('res-vacaciones').innerText = formatCOP(data.vacaciones);

                const valIndemnizacion = data.indemnizacion || data.indemnizacion_art_64 || 0;
                document.getElementById('res-indemnizacion').innerText = formatCOP(valIndemnizacion);
                document.getElementById('res-total').innerText = formatCOP(data.total || data.total_liquidacion);

                // Reveal Results Panel
                results.classList.remove('hidden');

                // Upsell Rule: Art 64 CST
                if (parseFloat(valIndemnizacion) > 0) {
                    ctaIndemnizacion.classList.remove('hidden');
                }

            } catch (error) {
                alert('Tuvimos un error conectando con el clÃºster de N8N. Verifica que el endpoint /calculadora-laboral estÃ© listado para solicitudes POST.');
                console.error(error);
                emptyState.classList.remove('hidden');
            } finally {
                btn.disabled = false;
                btn.classList.remove('opacity-70');
                spinner.classList.add('hidden');
            }
        }
        // Inicializar las Soluciones Guanes al cargar la pÃ¡gina
        document.addEventListener('DOMContentLoaded', cargarSolucionesGuanes);
    </script>
